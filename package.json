{
  "name": "carta-in-vscode",
  "displayName": "Carta in VS Code",
  "description": "Unofficial extension to run and view CARTA tool within VS Code. The official maintainers of CARTA can be found here https://cartavis.org/. The owners of CARTA were not involved in the development of this tool.",
  "version": "0.0.3",
  "publisher": "kwazzi-jack",
  "license": "MIT",
  "icon": "images/carta-for-vscode-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwazzi-jack/carta-in-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "carta-in-vscode.open",
        "title": "CARTA: Open Viewer"
      },
      {
        "command": "carta-in-vscode.stop",
        "title": "CARTA: Stop Server"
      }
    ],
    "configuration": {
      "title": "Carta in VS Code",
      "properties": {
        "carta-in-vscode.executablePath": {
          "type": "string",
          "default": "carta",
          "description": "Path to the CARTA executable. Defaults to 'carta' (assumes it's on your PATH)."
        },
        "carta-in-vscode.port": {
          "type": "number",
          "default": 3002,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port number for the CARTA server."
        },
        "carta-in-vscode.startupTimeout": {
          "type": "number",
          "default": 180000,
          "minimum": -1,
          "description": "Milliseconds to wait for the CARTA server to start before timing out. Defaults to -1 which is no timeout applied."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
