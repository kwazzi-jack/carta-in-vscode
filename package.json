{
  "name": "carta-in-vscode",
  "displayName": "Carta in VS Code",
  "description": "Unofficial extension to run and view CARTA tool within VS Code. The official maintainers of CARTA can be found here https://cartavis.org/. The owners of CARTA were not involved in the development of this tool.",
  "version": "0.1.4",
  "publisher": "kwazzi-jack",
  "license": "MIT",
  "icon": "images/carta-for-vscode-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwazzi-jack/carta-in-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "carta-in-vscode.open",
        "title": "CARTA: Open Viewer",
        "icon": "$(add)"
      },
      {
        "command": "carta-in-vscode.stop",
        "title": "CARTA: Stop Most Recent Viewer",
        "icon": "$(debug-stop)"
      },
      {
        "command": "carta-in-vscode.stopAll",
        "title": "CARTA: Stop ALL Viewers",
        "icon": "$(close-all)"
      },
      {
        "command": "carta-in-vscode.openWorkspace",
        "title": "CARTA: Open Viewer (Workspace Folder)"
      },
      {
        "command": "carta-in-vscode.openRecent",
        "title": "CARTA: Open Recent Folder...",
        "icon": "$(history)"
      },
      {
        "command": "carta-in-vscode.openInstance",
        "title": "CARTA: Open Viewer Instance"
      },
      {
        "command": "carta-in-vscode.stopInstance",
        "title": "CARTA: Stop Viewer Instance",
        "icon": "$(debug-stop)"
      },
      {
        "command": "carta-in-vscode.restartInstance",
        "title": "CARTA: Restart Viewer Instance",
        "icon": "$(refresh)"
      },
      {
        "command": "carta-in-vscode.copyInstanceId",
        "title": "CARTA: Copy Instance ID",
        "icon": "$(clippy)"
      },
      {
        "command": "carta-in-vscode.copyInstanceUrl",
        "title": "CARTA: Copy Instance URL"
      },
      {
        "command": "carta-in-vscode.copyInstanceToken",
        "title": "CARTA: Copy Instance Token"
      },
      {
        "command": "carta-in-vscode.copyInstanceSessionIds",
        "title": "CARTA: Copy Instance Session IDs"
      },
      {
        "command": "carta-in-vscode.focusInstance",
        "title": "CARTA: Focus Viewer Instance"
      },
      {
        "command": "carta-in-vscode.openInstanceFolder",
        "title": "CARTA: Open Instance Folder"
      },
      {
        "command": "carta-in-vscode.openInstanceLog",
        "title": "CARTA: Open Instance Log File"
      }
    ],
    "configuration": {
      "title": "Carta in VS Code",
      "properties": {
        "carta-in-vscode.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the CARTA executable. Empty defaults to 'carta' (assumes it's on your PATH)."
        },
        "carta-in-vscode.executableArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command line arguments to pass to the CARTA executable."
        },
        "carta-in-vscode.portRange": {
          "type": "string",
          "default": "3002-3099",
          "pattern": "^\\s*\\d{2,5}\\s*-\\s*\\d{2,5}\\s*$",
          "description": "Inclusive port range used for auto-selecting a free CARTA port (e.g. 3002-3099)."
        },
        "carta-in-vscode.startupTimeout": {
          "type": "number",
          "default": -1,
          "minimum": -1,
          "description": "Milliseconds to wait for the CARTA server to start before timing out. Defaults to -1 which is no timeout applied."
        },
        "carta-in-vscode.maxConcurrentServers": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of concurrently running CARTA servers."
        },
        "carta-in-vscode.viewerMode": {
          "type": "string",
          "enum": [
            "webview",
            "simpleBrowser",
            "externalBrowser"
          ],
          "default": "webview",
          "description": "Viewer surface used when opening a running CARTA instance."
        },
        "carta-in-vscode.browserExecutablePath": {
          "type": "string",
          "default": "",
          "description": "Optional browser executable path used when viewerMode is externalBrowser. Leave empty to use the OS default browser."
        },
        "carta-in-vscode.browserExecutableArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command line arguments to pass to the browser executable."
        },
        "carta-in-vscode.environmentVariables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Optional environment variables to set when launching a CARTA instance."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "carta-sidebar",
          "title": "CARTA",
          "icon": "images/carta-for-vscode-icon-activity-icon.svg"
        }
      ]
    },
    "views": {
      "carta-sidebar": [
        {
          "id": "carta-recent",
          "name": "Recent Folders"
        },
        {
          "id": "carta-running",
          "name": "Running Viewers"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "carta-running",
        "contents": "No running CARTA viewers.\n\n[$(add)](command:carta-in-vscode.open)\n\n"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "carta-in-vscode.open",
          "when": "view == carta-running",
          "group": "navigation@1"
        },
        {
          "command": "carta-in-vscode.openRecent",
          "when": "view == carta-running",
          "group": "navigation@2"
        },
        {
          "command": "carta-in-vscode.stopAll",
          "when": "view == carta-running",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "carta-in-vscode.restartInstance",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "inline@9"
        },
        {
          "command": "carta-in-vscode.stopInstance",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "inline@10"
        },
        {
          "command": "carta-in-vscode.focusInstance",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "navigation@1"
        },
        {
          "command": "carta-in-vscode.copyInstanceUrl",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "navigation@2"
        },
        {
          "command": "carta-in-vscode.copyInstanceToken",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "navigation@3"
        },
        {
          "command": "carta-in-vscode.copyInstanceSessionIds",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "navigation@4"
        },
        {
          "command": "carta-in-vscode.openInstanceFolder",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "navigation@5"
        },
        {
          "command": "carta-in-vscode.openInstanceLog",
          "when": "view == carta-running && viewItem == cartaInstance",
          "group": "navigation@6"
        }
      ],
      "commandPalette": [
        {
          "command": "carta-in-vscode.openInstance",
          "when": "false"
        },
        {
          "command": "carta-in-vscode.stopInstance",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
