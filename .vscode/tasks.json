// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "compile",
			"group": {
				"kind": "build"
			},
			"problemMatcher": "$tsc"
		},
		{
			"type": "npm",
			"script": "test",
			"group": {
				"kind": "test"
			}
		},
		{
			"label": "Release Extension",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/release.sh",
			"presentation": {
				"reveal": "always",
				"focus": true,
				"panel": "dedicated"
			},
			"problemMatcher": []
		}
	]
}
